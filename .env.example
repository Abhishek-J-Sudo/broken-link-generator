# =============================================================================
#  Coolify deployment reference. Copy real values into Coolify's Env panel.
#  Do NOT commit real secrets (this file is a template; .env.local is ignored).
# =============================================================================

# -----------------------------------------------------------------------------
#  Redis (BullMQ job queue — Coolify one-click Redis or any Redis 6+).
#  Used by both the web server (to enqueue jobs) and the worker (to consume them).
#  Use Coolify's INTERNAL connection string so traffic stays on the private network.
# -----------------------------------------------------------------------------
REDIS_URL=redis://seoscrub-redis:6379

# Number of crawl jobs the worker runs simultaneously (default 3)
# WORKER_CONCURRENCY=3

# -----------------------------------------------------------------------------
#  Database (plain PostgreSQL — e.g. Coolify's one-click Postgres).
#  All DB access is server-side, so there are NO build-time / NEXT_PUBLIC vars.
# -----------------------------------------------------------------------------
# Use Coolify's INTERNAL connection string (service name as host) so traffic
# stays on the internal network, e.g. postgres://user:pass@seoscrub-db:5432/seoscrub
DATABASE_URL=postgres://user:password@host:5432/seoscrub

# Set to 'true' only if your Postgres requires TLS (managed/external DB).
# Leave unset/false for Coolify-internal Postgres.
DATABASE_SSL=false

# Optional: max pooled connections (default 10)
# DATABASE_POOL_MAX=10

# Port the server listens on. Set Coolify "Ports Exposes" to the same value.
PORT=3000

# Public origin of the deployed app. Used for CORS (Access-Control-Allow-Origin)
# and links. Set to your Coolify domain, e.g. https://links.example.com
ALLOWED_ORIGIN=https://seoscrub.in
DEPLOYMENT_URL=https://seoscrub.in

# Security tokens (generate strong random values, e.g. `openssl rand -hex 32`)
CSRF_SECRET=change-me-32-byte-hex
CLEANUP_SECRET_TOKEN=change-me-32-byte-hex

# Basic auth gate (middleware.ts).
# In production, ENABLE_BASIC_AUTH=true is required — omitting it or leaving credentials
# empty causes ALL routes (except /api/health) to return 401.
# Password must be at least 12 characters and not "change-me"; the app will refuse to start
# in production otherwise.
ENABLE_BASIC_AUTH=true
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me-use-a-strong-password-here

# Crawler behaviour
CRAWLER_CONTACT_EMAIL=support@seoscrub.in
CRAWLER_USER_AGENT=SeoScrub Bot/1.0 (+https://seoscrub.in/bot)
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_MAX_CONCURRENT=3
CRAWLER_DEFAULT_DELAY=1000

# App environment / security
NODE_ENV=production
ENABLE_DETAILED_ERRORS=false
ENABLE_SECURITY_LOGGING=true
SECURITY_LEVEL=production
LOG_SECURITY_EVENTS=true
BLOCK_SUSPICIOUS_REQUESTS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Optional Smart Analyzer recommendations. When unset, scope estimates use the
# built-in deterministic rules and make no external AI request. With a key,
# one DeepSeek V4 Flash request is made per successful scope estimate; the
# integration sends aggregate category counts plus up to 10 URL patterns only.
DEEPSEEK_API_KEY=

# Optional Core Web Vitals (Performance snapshot cell, G7). Free Google
# PageSpeed Insights key — no billing required. Create one at
# https://developers.google.com/speed/docs/insights/v5/get-started (enable the
# "PageSpeed Insights API" and make an API key). When unset, the Performance
# cell reads "not measured"; the audit is otherwise unaffected. When set, one
# PSI call runs on the site homepage at first report view and is cached per job.
# NOTE: PSI fetches the URL from Google's servers, so the audited URL is sent
# to Google (fine for the public sites this tool audits).
PAGESPEED_API_KEY=

# Crawl limits
MAX_CRAWL_DEPTH=5
MAX_CRAWL_PAGES=1000
REQUEST_TIMEOUT=30000

# Contact form (Web3Forms — https://web3forms.com, free tier, email never exposed)
# Get your access key from the Web3Forms dashboard and paste it here.
NEXT_PUBLIC_WEB3FORMS_KEY=
